{
  "name": "ev-charging-session-service",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "npm run lint && npm run format:check",
    "start": "node --max-http-header-size 24000 src/server.js",
    "start:dist": "node --max-http-header-size 24000 dist/server.js",
    "start:dev": "PINO_LOG_LEVEL=debug NODE_ENV=local nodemon --watch src --exec \"node --max-http-header-size 24000\" src/server.js | pino-pretty -c -t -l severity",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand --watchman=false"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^6.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "ajv": "^8.18.0",
    "ajv-errors": "^3.0.0",
    "ajv-formats": "^3.0.1",
    "ajv-keywords": "^5.1.0",
    "crypto": "^1.0.1",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.4",
    "fastify-healthcheck": "^5.1.0",
    "fastify-plugin": "^5.1.0",
    "http-status-codes": "^2.3.0",
    "mongodb": "^7.1.1",
    "pino": "^10.3.1",
    "uuid": "^13.0.0"
  }
}
